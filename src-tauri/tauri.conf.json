{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "the-ninth-tile",
  "version": "0.1.0",
  "identifier": "com.jayantthakur.eight-puzzle",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/eight-puzzle/browser"
  },
  "app": {
    "windows": [
      {
        "title": "The Ninth Tile",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
